# PEAK3 Arena — API environment variables
# Copy to .env and fill in values (never commit .env)

# ---- Core ----
PEAK3_SIGNING_SECRET=change-me-in-production
PEAK3_DEBUG=true
PEAK3_CORS_ORIGINS=["http://localhost:3000"]
PEAK3_SESSION_TTL_SECONDS=86400

# ---- Phase 3.0 — Durable persistence (required in production) ----
# PostgreSQL connection string for durable game records, profiles, history.
# When unset in DEBUG mode, falls back to in-memory storage (state lost on restart).
# PEAK3_DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ---- Phase 3.0 — Supabase Auth (required for authenticated endpoints) ----
# JWT secret from your Supabase project: Settings > API > JWT Secret
# PEAK3_SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---- Supabase project details (optional — exposed to frontend separately) ----
# PEAK3_SUPABASE_URL=https://your-project.supabase.co
# PEAK3_SUPABASE_ANON_KEY=your-anon-key

# ---- Phase 4.0 — Ranked duels (closed alpha; disabled by default) ----
# Independent capability switches — do not use one flag for everything.
PEAK3_RANKED_ENABLED=false
PEAK3_RANKED_MATCHMAKING_ENABLED=false
PEAK3_RANKED_RATING_WRITES_ENABLED=false
PEAK3_RANKED_PUBLIC_LEADERBOARD_ENABLED=false
PEAK3_RANKED_ALPHA_ALLOWLIST=[]
# One of: disabled | simulation_only | internal_alpha | closed_alpha | public_beta
PEAK3_RANKED_READINESS_LEVEL=disabled

# ---- Phase 4.0 — Supabase integration-test mode (dedicated CI job only) ----
# Only used by apps/api/tests/integration/ (pytest -m supabase_integration).
# When unset, those tests report "not configured" and are skipped explicitly —
# never silently reported as passing.
# PEAK3_TEST_SUPABASE_URL=https://your-test-project.supabase.co
# PEAK3_TEST_SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key
# PEAK3_TEST_SUPABASE_ANON_KEY=your-test-anon-key
# PEAK3_TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
