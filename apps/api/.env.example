# PEAK3 Arena — API environment variables
# Copy to .env and fill in values (never commit .env)

# ---- Core ----
PEAK3_SIGNING_SECRET=change-me-in-production
PEAK3_DEBUG=true
PEAK3_CORS_ORIGINS=["http://localhost:3000"]
PEAK3_SESSION_TTL_SECONDS=86400

# ---- Phase 3.0 — Durable persistence (required in production) ----
# PostgreSQL connection string for durable game records, profiles, history.
# When unset in DEBUG mode, falls back to in-memory storage (state lost on restart).
# Local Supabase stack (see the Phase 4.0A section below): this is DB_URL
# from `supabase status`, e.g.:
# PEAK3_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ---- Phase 3.0 — Supabase Auth (required for authenticated endpoints) ----
# JWT secret from your Supabase project: Settings > API > JWT Secret.
# Local stack: this is JWT_SECRET from `supabase status`.
# PEAK3_SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---- Supabase project details (optional — exposed to frontend separately) ----
# Local stack: PEAK3_SUPABASE_URL is API_URL, PEAK3_SUPABASE_ANON_KEY is
# ANON_KEY (or PUBLISHABLE_KEY) from `supabase status`.
# PEAK3_SUPABASE_URL=https://your-project.supabase.co
# PEAK3_SUPABASE_ANON_KEY=your-anon-key

# ---- Phase 4.0A — Local Supabase stack (dev only; never a hosted project) ----
# Run once: `npx supabase init` (already committed under supabase/), then:
#   npx supabase start        # boots the local stack (Docker)
#   npx supabase status       # prints the values below
#   npx supabase db reset     # replays supabase/migrations/ from scratch
# `supabase status` maps directly onto the vars above and below:
#   DB_URL            -> PEAK3_DATABASE_URL / PEAK3_TEST_DATABASE_URL
#   API_URL            -> PEAK3_SUPABASE_URL / PEAK3_TEST_SUPABASE_URL
#   ANON_KEY (or PUBLISHABLE_KEY) -> PEAK3_SUPABASE_ANON_KEY / PEAK3_TEST_SUPABASE_ANON_KEY
#   SERVICE_ROLE_KEY   -> PEAK3_TEST_SUPABASE_SERVICE_ROLE_KEY (server/test-only — never bundled into the frontend)
#   JWT_SECRET         -> PEAK3_SUPABASE_JWT_SECRET / PEAK3_TEST_SUPABASE_JWT_SECRET
# This project deliberately does NOT run `supabase link` or `supabase db
# push`/`pull` against any hosted project — see docs/implementation/LOCAL_DEV.md.
# Local dev with no env set at all falls back to in-memory repositories (see
# the startup log line "Repository registry: memory (N/N domains)" — a loud,
# explicit warning, not a silent default) — set the vars above to use the
# local Postgres/Auth stack instead.

# ---- Phase 4.0 — Ranked duels (closed alpha; disabled by default) ----
# Independent capability switches — do not use one flag for everything.
PEAK3_RANKED_ENABLED=false
PEAK3_RANKED_MATCHMAKING_ENABLED=false
PEAK3_RANKED_RATING_WRITES_ENABLED=false
PEAK3_RANKED_PUBLIC_LEADERBOARD_ENABLED=false
PEAK3_RANKED_ALPHA_ALLOWLIST=[]
# One of: disabled | simulation_only | internal_alpha | closed_alpha | public_beta
PEAK3_RANKED_READINESS_LEVEL=disabled

# ---- Phase 4.0/4.0A — Supabase integration-test mode ----
# Used by apps/api/tests/integration/ (pytest -m supabase_integration) and by
# tests/test_repository_conformance.py's PostgreSQL half. When unset, those
# tests report "not configured" / skip explicitly — never silently reported
# as passing. As of Phase 4.0A these CAN be pointed at the local Supabase
# stack above (same values as PEAK3_DATABASE_URL/PEAK3_SUPABASE_URL etc,
# just under the TEST_ prefix so a real hosted test project can be swapped in
# later without code changes) — this is still local-only, never a hosted
# project, per this phase's explicit constraints.
# PEAK3_TEST_SUPABASE_URL=http://127.0.0.1:54321
# PEAK3_TEST_SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key
# PEAK3_TEST_SUPABASE_ANON_KEY=your-test-anon-key
# PEAK3_TEST_SUPABASE_JWT_SECRET=your-test-jwt-secret
# PEAK3_TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
