# PEAK3 Arena — Web environment variables
# Copy to .env.local and fill in values (never commit .env.local)

# API base URL (where the FastAPI app is running)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Phase 3.0 — Supabase Auth (optional — auth features disabled when unset) ----
# Your Supabase project URL: Settings > API > Project URL
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key: Settings > API > anon public
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
